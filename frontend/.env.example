# SmartBudget Frontend — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git (it is covered by *.local in .gitignore).
# See README.md → "Run locally" for full setup instructions.

# Full URL of the backend API (no trailing slash).
# Local development: http://localhost:5000
# Production: set to your Render service URL (e.g. https://smartbudget-api-r5kp.onrender.com)
# NOTE: Vite env vars MUST start with VITE_ to be exposed to the browser bundle.
VITE_API_URL=http://localhost:5000
