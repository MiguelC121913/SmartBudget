# SmartBudget Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# See README.md → "Run locally" for full setup instructions.

# Server port (Render assigns this automatically in production)
PORT=5000

# MongoDB Atlas connection string
# Get it from: Atlas dashboard → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartbudget

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_64_char_hex_string

# AES-256-GCM key for encrypting user API keys — must be exactly 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=replace_with_random_64_char_hex_string_representing_32_bytes

# Anthropic API key for server-side (demo mode) categorization and reports
# Get it from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-server-key-here

# 'development' locally, 'production' on Render
NODE_ENV=development

# URL of the deployed frontend — used by CORS to allow only this origin in production
# Example: https://smartbudget-chi.vercel.app
FRONTEND_URL=http://localhost:5173
